---
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Message Sent | Abdul Rehman"
  description="Your message was sent successfully."
  noindex={true}
>
  <div class="flex min-h-screen flex-col supports-[height:100dvh]:min-h-dvh">
    <Navbar />
    <div class="mx-auto flex w-full max-w-3xl flex-1 flex-col px-8">
      <main class="flex grow items-center">
        <section class="w-full rounded-xl border border-white/10 bg-white/5 p-8 text-center">
          <h1 class="text-3xl font-bold text-white sm:text-4xl">Message sent</h1>
          <p class="mx-auto mt-4 max-w-md text-sm text-white/75 sm:text-base">
            Thanks for reaching out. I will get back to you as soon as possible.
          </p>
          <a
            href="/"
            class="mt-8 inline-flex rounded-md bg-[#a2f778] px-4 py-2 text-sm font-semibold text-black transition-colors hover:bg-[#b8ff96]"
          >
            Back to home
          </a>
        </section>
      </main>
    </div>
    <Footer />
  </div>
</Layout>
