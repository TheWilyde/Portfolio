---
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 | Page Not Found"
  description="The page you requested could not be found."
  noindex={true}
>
  <div class="flex min-h-screen flex-col supports-[height:100dvh]:min-h-[100dvh]">
    <Navbar />
    <div class="mx-auto flex w-full max-w-3xl flex-1 flex-col px-8">
      <main class="flex grow items-center">
        <section class="w-full rounded-xl border border-white/10 bg-white/5 p-8 text-center">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-white/60">404</p>
          <h1 class="mt-3 text-3xl font-bold text-white sm:text-4xl">Page not found</h1>
          <p class="mx-auto mt-4 max-w-md text-sm text-white/75 sm:text-base">
            This page may have moved or never existed.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/"
              class="rounded-md bg-[#a2f778] px-4 py-2 text-sm font-semibold text-black transition-colors hover:bg-[#b8ff96]"
            >
              Go home
            </a>
            <a
              href="/projects"
              class="rounded-md border border-white/20 px-4 py-2 text-sm font-semibold text-white transition-colors hover:border-white/40"
            >
              Projects
            </a>
            <a
              href="/blogs"
              class="rounded-md border border-white/20 px-4 py-2 text-sm font-semibold text-white transition-colors hover:border-white/40"
            >
              Blogs
            </a>
          </div>
        </section>
      </main>
    </div>
    <Footer />
  </div>
</Layout>
