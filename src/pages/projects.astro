---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects.js";
---

<Layout title="Abdul Rehman | Projects">
  <div class="flex min-h-screen flex-col supports-[height:100dvh]:min-h-[100dvh]">
    <Navbar />
    <div class="mx-auto flex w-full max-w-3xl flex-1 flex-col px-8">
      <main class="grow">
        <article class="mt-8 flex flex-col gap-8 pb-16">
          <h1 class="text-3xl font-bold text-white sm:text-4xl">My Projects</h1>

          {
            projects.length === 0 ? (
              <div class="rounded-xl border border-white/10 bg-white/5 p-6 text-center">
                <p class="text-sm text-white/80">
                  No projects yet. Building in multiverse. Check back soon.
                </p>
              </div>
            ) : (
              <section class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                {projects.map((project) => <ProjectCard project={project} />)}
              </section>
            )
          }
        </article>
      </main>
    </div>
    <Footer />
  </div>
</Layout>
