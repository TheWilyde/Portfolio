---
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact | Abdul Rehman"
  description="Get in touch with Abdul Rehman for freelance and full-time opportunities."
>
  <div class="flex min-h-screen flex-col supports-[height:100dvh]:min-h-[100dvh]">
    <Navbar />
    <div class="mx-auto flex w-full max-w-3xl flex-1 flex-col px-8">
      <main class="grow">
        <article class="mt-8 pb-16">
          <h1 class="text-3xl font-bold text-white sm:text-4xl">Contact</h1>
          <p class="mt-3 max-w-xl text-sm text-white/75 sm:text-base">
            Planning a build, redesign, or collaboration? Send details below.
          </p>

          <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6 sm:p-8">
            <ContactForm />
          </div>
        </article>
      </main>
    </div>
    <Footer />
  </div>
</Layout>
