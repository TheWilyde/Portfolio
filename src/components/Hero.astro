---
import ProfileImage from "../assets/ProfilePhoto.webp";
import GitHubIcon from "../assets/icons/github.svg";
import LinkedInIcon from "../assets/icons/linkedin.svg";
import { ArrowDownRight, FileDown, Mail } from "@lucide/astro";
import { Image } from "astro:assets";

const socialLinks = [
  {
    name: "LinkedIn",
    icon: LinkedInIcon,
    href: "https://www.linkedin.com/in/wilyde/",
  },
  {
    name: "GitHub",
    icon: GitHubIcon,
    href: "https://github.com/TheWilyde",
  },
  {
    name: "Email",
    icon: Mail,
    href: "mailto:thewilyde@gmail.com",
  },
];
---

<section
  class="flex flex-col items-start gap-8 md:flex-row-reverse md:items-center md:justify-between"
>
  <Image
    src={ProfileImage}
    alt="Muhammad Abdul Rehman Khan"
    width={175}
    height={263}
    sizes="175px"
    fetchpriority="high"
    class="rounded-lg w-[175px] h-[263px] object-cover"
  />

  <div class="flex max-w-[320px] flex-col sm:max-w-full">
    <h1 class="text-balance text-4xl font-bold text-white sm:text-5xl">
      I'm Abdul Rehman
    </h1>
    <p class="mt-2 whitespace-nowrap text-sm font-medium text-white/90 sm:text-base">
      Software Engineer from Pakistan
    </p>
    <p class="mt-4 max-w-sm text-balance text-sm text-white/90 sm:text-base">
      Full-stack developer passionate about creating innovative solutions and beautiful user
      experiences.
    </p>

    <p class="mt-6 inline-flex items-center gap-1 text-balance text-sm font-semibold text-white sm:text-base">
      Let's connect and build something amazing
      <ArrowDownRight aria-hidden="true" class="hidden sm:inline" size={24} />
    </p>

    <section class="social-row mt-6 flex flex-wrap items-center gap-6">
      <a
        href="/Resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="resume-btn relative inline-flex items-center justify-center overflow-hidden rounded-md border border-[#a2f778] bg-[#a2f778] px-4 py-2 text-sm font-medium text-black"
      >
        <span class="inline-flex items-center gap-2">
          Resume
          <FileDown size={16} />
        </span>
      </a>

      <div class="flex min-w-24 justify-between gap-2">
        {
          socialLinks.map((link) => {
            const Icon = link.icon;
            return (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="social-pill inline-flex h-8 w-8 items-center justify-center rounded-full border border-white/40 text-xs font-semibold text-white transition-colors duration-200"
                title={link.name}
              >
                <span class="sr-only">{link.name}</span>
                <Icon aria-hidden="true" width={16} height={16} />
              </a>
            );
          })
        }
      </div>
    </section>
  </div>
</section>
